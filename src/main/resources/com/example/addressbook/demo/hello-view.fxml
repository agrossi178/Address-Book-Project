<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.text.Text?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.addressbook.demo.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label>Welcome to the address book application. Before you proceed you must agree to the following terms and conditions</Label>
    <TextArea></TextArea>
    <CheckBox fx:id="checkBox" text="I agree to the terms and conditions" onAction="#onAgreeCheckBoxClick"/>
    <Button fx:id="cancel" text="Cancel" onAction="#onCancelClick"/>
    <Button fx:id="next" text="Next"/>
</VBox>
